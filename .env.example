// .env.example
// Copy to .env.local and fill in. Never commit real secrets.

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# LinkedIn Marketing API
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Instagram Graph API (via Meta)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook Graph API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Twitter / X API v2
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USER_ID=

# Public profile URLs (used in UI deep-links)
PLATFORM_URL_YOUTUBE=https://www.youtube.com/@ScalioApp
PLATFORM_URL_LINKEDIN=https://www.linkedin.com/company/scalioapp/
PLATFORM_URL_INSTAGRAM=https://www.instagram.com/scalio.app/
PLATFORM_URL_FACEBOOK=
PLATFORM_URL_TWITTER=
